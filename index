<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NOVA BIOTECH | Elite Research Chile</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">
    
    <style>
        :root {
            --bg-main: #ffffff;
            --bg-secondary: #f5f5f7;
            --accent-cyber: #00f2ff; /* Neón Ice */
            --accent-deep: #0055ff;
            --text-main: #1d1d1f;
            --text-dim: #86868b;
            --glass-border: rgba(0, 0, 0, 0.08);
            --transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
        }

        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Inter', -apple-system, sans-serif; scroll-behavior: smooth; }

        body {
            background-color: var(--bg-main);
            color: var(--text-main);
            overflow-x: hidden;
            -webkit-font-smoothing: antialiased;
        }

        /* --- CAPAS AMBIENTALES --- */
        .noise { position: fixed; inset: 0; background: url('https://grainy-gradients.vercel.app/noise.svg'); opacity: 0.03; pointer-events: none; z-index: 9999; }
        .grid-bg { position: fixed; inset: 0; background-image: linear-gradient(var(--glass-border) 1px, transparent 1px), linear-gradient(90deg, var(--glass-border) 1px, transparent 1px); background-size: 60px 60px; z-index: -1; opacity: 0.4; }

        /* --- NAVEGACIÓN --- */
        nav {
            position: fixed; top: 0; width: 100%; padding: 1.5rem 5%; display: flex; justify-content: space-between; align-items: center; z-index: 1000;
            background: rgba(255, 255, 255, 0.7); backdrop-filter: blur(25px); border-bottom: 1px solid var(--glass-border);
        }
        .logo { font-weight: 800; font-size: 1.5rem; letter-spacing: -1.5px; cursor: pointer; transition: 0.3s; }
        .logo:hover { color: var(--accent-cyber); }
        .nav-links { display: flex; gap: 3rem; align-items: center; }
        .nav-links a { text-decoration: none; color: var(--text-dim); font-size: 0.9rem; font-weight: 600; transition: var(--transition); position: relative; }
        .nav-links a::after { content: ''; position: absolute; bottom: -5px; left: 0; width: 0; height: 2px; background: var(--accent-cyber); transition: 0.3s; }
        .nav-links a:hover { color: #000; }
        .nav-links a:hover::after { width: 100%; }
        .cart-icon { cursor: pointer; background: #000; color: #fff; padding: 10px 22px; border-radius: 100px; font-size: 0.85rem; font-weight: 700; transition: var(--transition); }
        .cart-icon:hover { transform: scale(1.05); background: var(--accent-deep); }

        /* --- SECCIONES DIAGONALES --- */
        section { padding: 120px 10%; position: relative; }
        .diagonal-hero { clip-path: polygon(0 0, 100% 0, 100% 88%, 0 100%); background: #fbfbfd; padding-top: 240px; padding-bottom: 180px; text-align: center; }
        .diagonal-white { clip-path: polygon(0 6%, 100% 0, 100% 94%, 0 100%); background: #fff; border-top: 1px solid var(--glass-border); border-bottom: 1px solid var(--glass-border); }

        .hero-title { font-size: clamp(3rem, 7vw, 6rem); font-weight: 800; letter-spacing: -5px; line-height: 0.9; margin-bottom: 2.5rem; opacity: 0; transform: translateY(40px); }
        .reveal { opacity: 1 !important; transform: translateY(0) !important; transition: all 1.2s cubic-bezier(0.16, 1, 0.3, 1); }

        /* --- APPLE CARDS (CIENCIA) --- */
        .apple-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 2.5rem; margin-top: 4rem; }
        .apple-card {
            background: #fff; padding: 4rem 2.5rem; border-radius: 35px; border: 1px solid rgba(0,0,0,0.04); transition: var(--transition); cursor: default;
        }
        .apple-card:hover { transform: translateY(-10px); border-color: var(--accent-cyber); box-shadow: 0 30px 60px rgba(0,0,0,0.05); }
        .apple-card h3 { font-size: 2rem; letter-spacing: -1.5px; margin-bottom: 1.5rem; line-height: 1.1; }

        /* --- TARJETAS PÉPTIDOS (VERTICALES) --- */
        .peptide-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 3rem; margin-top: 5rem; }
        .peptide-card {
            background: #fff; border: 2px solid var(--glass-border); border-radius: 40px; overflow: hidden; transition: var(--transition); cursor: pointer; display: flex; flex-direction: column; position: relative;
        }
        .peptide-card:hover { transform: translateY(-15px); border-color: var(--accent-cyber); box-shadow: 0 40px 80px rgba(0, 242, 255, 0.15); }
        
        .peptide-img { width: 100%; height: 320px; object-fit: cover; transition: 0.8s; filter: grayscale(20%); }
        .peptide-card:hover .peptide-img { transform: scale(1.05); filter: grayscale(0%); }
        
        .peptide-info { padding: 2.5rem; display: flex; flex-direction: column; flex-grow: 1; }
        .peptide-cat { font-size: 0.75rem; font-weight: 800; color: var(--accent-deep); text-transform: uppercase; letter-spacing: 2px; margin-bottom: 1rem; }
        .peptide-name { font-size: 2.2rem; font-weight: 800; letter-spacing: -2px; line-height: 1; margin-bottom: 1rem; }
        .peptide-desc { color: var(--text-dim); font-size: 1rem; margin-bottom: 2rem; line-height: 1.5; }
        
        .price-tag { font-size: 1.8rem; font-weight: 800; color: #000; margin-bottom: 2rem; margin-top: auto; }
        .btn-add { width: 100%; padding: 1.2rem; border-radius: 20px; border: none; background: #f2f2f7; color: #000; font-weight: 800; cursor: pointer; transition: 0.3s; }
        .btn-add:hover { background: #000; color: #fff; transform: scale(1.02); }

        /* --- TRAZABILIDAD COA --- */
        .coa-box { background: var(--bg-secondary); border-radius: 50px; padding: 5rem; margin-top: 5rem; border: 1px solid var(--glass-border); text-align: left; }
        .coa-input { display: flex; gap: 1rem; margin-top: 3rem; max-width: 600px; }
        .coa-input input { flex-grow: 1; margin: 0; background: #fff; border-radius: 20px; border: 1px solid transparent; padding: 1.2rem; outline: none; transition: 0.3s; }
        .coa-input input:focus { border-color: var(--accent-cyber); }

        /* --- MODALES --- */
        .modal-overlay { position: fixed; inset: 0; background: rgba(255,255,255,0.98); backdrop-filter: blur(20px); z-index: 2000; display: none; padding: 5%; overflow-y: auto; }
        .modal-content { max-width: 1000px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; padding-top: 60px; }
        .modal-close { position: fixed; top: 40px; right: 40px; font-size: 3rem; cursor: pointer; font-weight: 200; z-index: 2100; transition: 0.3s; }
        .modal-close:hover { color: var(--accent-cyber); transform: rotate(90deg); }

        /* --- FOOTER & DISCLAIMER --- */
        .disclaimer-box { font-size: 0.8rem; color: #ff3b30; background: rgba(255,59,48,0.04); padding: 3rem; border-radius: 30px; border: 1px solid rgba(255, 59, 48, 0.15); line-height: 1.8; margin-top: 4rem; }
        .disclaimer-box strong { text-transform: uppercase; letter-spacing: 1px; }

        /* --- CARRITO DRAW --- */
        #cart-drawer { position: fixed; right: -100%; top: 0; width: 100%; max-width: 500px; height: 100vh; background: #fff; z-index: 1001; padding: 5rem 3rem; transition: var(--transition); box-shadow: -40px 0 100px rgba(0,0,0,0.08); display: flex; flex-direction: column; }
        #cart-drawer.active { right: 0; }
        .cart-item { display: flex; justify-content: space-between; align-items: center; padding: 2rem 0; border-bottom: 1px solid var(--glass-border); }

        .btn-black { background: #000; color: #fff; padding: 1.4rem; border-radius: 22px; border: none; font-weight: 700; cursor: pointer; width: 100%; transition: 0.3s; text-transform: uppercase; letter-spacing: 1px; }
        .btn-black:hover { background: var(--accent-cyber); color: #000; transform: translateY(-2px); }

        @media (max-width: 900px) { .modal-content { grid-template-columns: 1fr; } section { padding: 100px 5%; } .coa-input { flex-direction: column; } }
    </style>
</head>
<body>

    <div class="noise"></div>
    <div class="grid-bg"></div>

    <!-- NAV -->
    <nav>
        <div class="logo" onclick="window.scrollTo({top:0, behavior:'smooth'})">NOVA</div>
        <div class="nav-links">
            <a href="#ciencia">Ciencia</a>
            <a href="#peptidos">Péptidos</a>
            <a href="#trazabilidad">COA</a>
            <div class="cart-icon" onclick="toggleCart()">
                PEDIDO (<span id="cart-count">0</span>)
            </div>
        </div>
    </nav>

    <main id="main-content">
        <!-- HERO -->
        <section class="diagonal-hero">
            <div class="reveal">
                <h1 class="hero-title">Optimización celular<br><span style="color: var(--accent-cyber)">Biohacking Élite.</span></h1>
                <p style="color: var(--text-dim); max-width: 700px; margin: 0 auto 4rem; font-size: 1.3rem; line-height: 1.6;">
                    Péptidos de alta pureza diseñados para protocolos de investigación de vanguardia. Trazabilidad absoluta y logística de alto estándar en Chile.
                </p>
                <button class="btn-black" style="width: auto; padding: 1.4rem 5rem;" onclick="document.getElementById('peptidos').scrollIntoView()">ENTRAR AL CATÁLOGO</button>
            </div>
        </section>

        <!-- CIENCIA CLARA -->
        <section id="ciencia" class="diagonal-white">
            <div class="reveal">
                <h2 style="font-size: 3rem; letter-spacing: -3px; margin-bottom: 1rem;">Péptidos en ciencia clara.</h2>
                <p style="color: var(--text-dim); margin-bottom: 4rem;">Fundamentos de señalización celular para biohackers e investigadores.</p>
                
                <div class="apple-grid">
                    <div class="apple-card">
                        <span style="color: var(--accent-cyber); font-weight: 800; font-size: 0.8rem; letter-spacing: 2px;">01 BIOLOGÍA</span>
                        <h3>¿Qué son los péptidos?</h3>
                        <p>Son biopolímeros de aminoácidos de cadena corta. Actúan como "llaves maestras" moleculares que disparan cascadas enzimáticas específicas sin la complejidad inmunogénica de las proteínas grandes.</p>
                    </div>
                    <div class="apple-card">
                        <span style="color: var(--accent-cyber); font-weight: 800; font-size: 0.8rem; letter-spacing: 2px;">02 PUREZA</span>
                        <h3>HPLC & Síntesis</h3>
                        <p>La pureza no es una opción. Cada lote es verificado por cromatografía líquida de alta resolución, garantizando >99% de precisión estructural en cada microgramo liofilizado.</p>
                    </div>
                    <div class="apple-card">
                        <span style="color: var(--accent-cyber); font-weight: 800; font-size: 0.8rem; letter-spacing: 2px;">03 INVESTIGACIÓN</span>
                        <h3>Uso R&D</h3>
                        <p>Destinados al estudio de la autofagia, la modulación hormonal y el rejuvenecimiento tisular. El límite de la biología humana está siendo reescrito en el laboratorio.</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- CATÁLOGO DE PÉPTIDOS -->
        <section id="peptidos">
            <div class="reveal">
                <h2 style="font-size: 3rem; letter-spacing: -3px; text-align: center; margin-bottom: 1rem;">Péptidos de Investigación</h2>
                <p style="text-align: center; color: var(--text-dim); margin-bottom: 5rem;">Selecciona un compuesto para ver su ficha técnica completa.</p>
                
                <div class="peptide-grid" id="product-list">
                    <!-- Contenido dinámico mediante JavaScript -->
                </div>
            </div>
        </section>

        <!-- TRAZABILIDAD COA -->
        <section id="trazabilidad">
            <div class="reveal coa-box">
                <h2 style="font-size: 2.8rem; letter-spacing: -2px; margin-bottom: 1rem;">Rastreo de Lote (COA)</h2>
                <p style="color: var(--text-dim); max-width: 600px;">Verifica la pureza analítica de tu vial. Ingresa el código de lote impreso en la etiqueta para visualizar el certificado de análisis.</p>
                
                <div class="coa-input">
                    <input type="text" id="batch-code" placeholder="Ej: NV-GHK882">
                    <button class="btn-black" style="width: auto; padding: 0 3rem;" onclick="traceBatch()">OBTENER COA</button>
                </div>
                <div id="coa-result" style="margin-top: 3rem; display: none; padding: 2.5rem; background: #fff; border-radius: 30px; border-left: 5px solid var(--accent-cyber);">
                    <p style="font-family: 'JetBrains Mono'; color: var(--accent-deep); font-weight: 700;">[RESULTADO: LOTE VERIFICADO - PUREZA 99.8% - LIBRE DE ENDOTOXINAS]</p>
                    <p style="margin-top: 10px; font-size: 0.9rem; color: var(--text-dim);">Análisis HPLC y Espectrometría de Masas coinciden con el estándar de referencia.</p>
                </div>
            </div>
        </section>

        <!-- FOOTER -->
        <footer style="padding: 100px 10% 60px;">
            <div class="disclaimer-box">
                <strong>CLÁUSULA DE EXENCIÓN DE RESPONSABILIDAD TOTAL:</strong> 
                Todos los productos de NOVA BIOTECH están destinados exclusivamente a fines de investigación y desarrollo (I+D) en entornos controlados de laboratorio. 
                <br><br>
                <strong>NO APTO PARA CONSUMO HUMANO.</strong> 
                NOVA BIOTECH <u>no se hace responsable bajo ninguna circunstancia, legal o civil</u>, por el uso indebido, administración personal, accidentes o efectos adversos derivados del manejo de estos péptidos. Al adquirir estos productos, el cliente reconoce que es un profesional calificado y asume la responsabilidad total de su custodia y uso, liberando a la marca de toda responsabilidad presente y futura.
            </div>
            <div style="text-align: center; margin-top: 5rem;">
                <p style="color: var(--text-dim); font-size: 0.9rem;">© 2024 NOVA BIOTECH CHILE | CIENCIA, PUREZA Y RENDIMIENTO.</p>
            </div>
        </footer>
    </main>

    <!-- MODAL PRODUCTO -->
    <div id="product-modal" class="modal-overlay">
        <span class="modal-close" onclick="closeProductModal()">&times;</span>
        <div class="modal-content" id="modal-body">
            <!-- Dinámico -->
        </div>
    </div>

    <!-- CARRITO DRAW -->
    <div id="cart-drawer">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 3rem;">
            <h2 style="font-size: 2rem; letter-spacing: -2px;">TU ORDEN</h2>
            <button onclick="toggleCart()" style="background:none; border:none; font-size: 2.5rem; cursor:pointer;">&times;</button>
        </div>
        <div id="cart-items" style="flex-grow: 1; overflow-y: auto;"></div>
        <div style="border-top: 1px solid var(--glass-border); padding-top: 3rem;">
            <div style="display: flex; justify-content: space-between; margin-bottom: 3rem; font-size: 1.6rem; font-weight: 800;">
                <span>Total:</span>
                <span id="cart-total">$0</span>
            </div>
            <button class="btn-black" onclick="openCheckout()">CONTINUAR AL PAGO</button>
        </div>
    </div>

    <script>
        const products = [
            { 
                id: 1, 
                name: "GHK-Cu", 
                cat: "Señalización Tisular", 
                short: "Inductor de colágeno y remodelación celular avanzada.",
                price: 85000,
                img: "https://images.unsplash.com/photo-1582719471384-894fbb16e074?q=80&w=1000&auto=format&fit=crop",
                info: "El GHK-Cu es un complejo tripeptídico de cobre con alta afinidad por receptores de matriz extracelular. En investigación, se utiliza para estudiar la regeneración de tejidos, la angiogénesis y la modulación de la expresión génica antienvejecimiento.",
                specs: ["Pureza HPLC: >99.4%", "Vial: 50mg liofilizado", "Formato: Polvo Azul", "R&D Grade"]
            },
            { 
                id: 2, 
                name: "Retatrutide", 
                cat: "Triple Agonista", 
                short: "Investigación metabólica de receptores GLP-1, GIP y GCG.",
                price: 198000,
                img: "https://images.unsplash.com/photo-1532187875605-2fe35877c467?q=80&w=1000&auto=format&fit=crop",
                info: "Molécula de frontera para el estudio de la homeostasis energética. Este péptido experimental interactúa con tres ejes hormonales distintos, permitiendo estudios complejos sobre la sensibilidad a la insulina y la lipólisis celular.",
                specs: ["Pureza HPLC: >99.7%", "Vial: 10mg liofilizado", "Uso: Estudios metabólicos", "Origen: Síntesis Certificada"]
            },
            { 
                id: 3, 
                name: "Tesamorelin", 
                cat: "Análogo de GHRH", 
                short: "Análogo sintético para estudios de señalización hipofisaria.",
                price: 135000,
                img: "https://images.unsplash.com/photo-1579165233006-2240ee03137a?q=80&w=1000&auto=format&fit=crop",
                info: "Factor liberador de hormona de crecimiento de alta potencia. Utilizado en investigación para mapear la liberación pulsátil de GH y estudiar la reducción de tejido adiposo visceral en modelos de lipodistrofia.",
                specs: ["Pureza HPLC: >99.1%", "Vial: 2mg liofilizado", "Secuencia: 44 aminoácidos", "Batch: Nov-2024"]
            }
        ];

        let cart = JSON.parse(localStorage.getItem('nova_final_cart')) || [];

        function initAnimations() {
            const obs = new IntersectionObserver(entries => {
                entries.forEach(e => { 
                    if(e.isIntersecting) e.target.classList.add('reveal'); 
                });
            }, { threshold: 0.1 });
            document.querySelectorAll('.reveal, .hero-title').forEach(el => obs.observe(el));
        }

        function renderProducts() {
            const fmt = new Intl.NumberFormat('es-CL', { style: 'currency', currency: 'CLP', maximumFractionDigits: 0 });
            document.getElementById('product-list').innerHTML = products.map(p => `
                <div class="peptide-card reveal" onclick="openProductModal(${p.id})">
                    <img src="${p.img}" class="peptide-img" alt="${p.name}">
                    <div class="peptide-info">
                        <span class="peptide-cat">${p.cat}</span>
                        <h3 class="peptide-name">${p.name}</h3>
                        <p class="peptide-desc">${p.short}</p>
                        <p class="price-tag">${fmt.format(p.price)}</p>
                        <button class="btn-add" onclick="event.stopPropagation(); addToCart(${p.id})">Añadir</button>
                    </div>
                </div>
            `).join('');
        }

        function openProductModal(id) {
            const p = products.find(x => x.id === id);
            const body = document.getElementById('modal-body');
            body.innerHTML = `
                <img src="${p.img}" style="width:100%; height:450px; object-fit:cover; border-radius:40px;">
                <div>
                    <h1 style="font-size: 3.5rem; letter-spacing: -3px; line-height: 1;">${p.name}</h1>
                    <p style="color: var(--accent-cyber); font-weight: 800; font-size: 1.2rem; margin: 1rem 0;">${p.cat}</p>
                    <p style="color: var(--text-dim); line-height: 1.8; font-size: 1.1rem; margin-bottom: 2.5rem;">${p.info}</p>
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                        ${p.specs.map(s => `<div style="padding: 1rem; background: var(--bg-secondary); border-radius: 15px; font-size: 0.85rem;"><strong>${s}</strong></div>`).join('')}
                    </div>
                    <button class="btn-black" style="margin-top: 3rem;" onclick="addToCart(${p.id}); closeProductModal();">AÑADIR AL CARRITO</button>
                </div>
            `;
            document.getElementById('product-modal').style.display = 'block';
            document.body.style.overflow = 'hidden';
        }

        function closeProductModal() { 
            document.getElementById('product-modal').style.display = 'none'; 
            document.body.style.overflow = 'auto'; 
        }

        function toggleCart() { 
            document.getElementById('cart-drawer').classList.toggle('active'); 
        }

        function addToCart(id) {
            const p = products.find(x => x.id === id);
            const exists = cart.find(x => x.id === id);
            if(exists) exists.qty++; else cart.push({...p, qty: 1});
            updateCart();
            if(!document.getElementById('cart-drawer').classList.contains('active')) toggleCart();
        }

        function updateCart() {
            const fmt = new Intl.NumberFormat('es-CL', { style: 'currency', currency: 'CLP', maximumFractionDigits: 0 });
            localStorage.setItem('nova_final_cart', JSON.stringify(cart));
            document.getElementById('cart-count').innerText = cart.reduce((a, b) => a + b.qty, 0);
            document.getElementById('cart-items').innerHTML = cart.map(item => `
                <div class="cart-item">
                    <div><strong>${item.name}</strong><br><small>${item.qty} unidad(es)</small></div>
                    <div style="text-align: right;">
                        <div style="font-weight: 800;">${fmt.format(item.price * item.qty)}</div>
                        <button onclick="removeItem(${item.id})" style="background:none; border:none; color:#ff3b30; cursor:pointer; font-size: 0.75rem; margin-top: 5px;">Eliminar</button>
                    </div>
                </div>
            `).join('');
            const total = cart.reduce((a, b) => a + (b.price * b.qty), 0);
            document.getElementById('cart-total').innerText = fmt.format(total);
        }

        function removeItem(id) { 
            cart = cart.filter(x => x.id !== id); 
            updateCart(); 
        }

        function openCheckout() {
            if(cart.length === 0) return;
            const id = "ORDER-CL-" + Math.floor(Math.random()*90000 + 10000);
            alert(`ORDEN GENERADA: ${id}\n\nPor favor contacte a ventas@novabiotech.cl para los datos de transferencia bancaria.`);
        }

        function traceBatch() {
            if(!document.getElementById('batch-code').value) return;
            document.getElementById('coa-result').style.display = 'block';
        }

        window.onload = () => { 
            renderProducts(); 
            updateCart(); 
            initAnimations(); 
        };
    </script>
</body>
</html>
